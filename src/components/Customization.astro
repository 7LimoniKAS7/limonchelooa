---
import type { Messages } from "../i18n/messages";

interface Props {
  t: Messages;
}

const { t } = Astro.props;
---

<section
  id="customize"
  class="scroll-mt-24 border-y border-gold-light/20 bg-gradient-to-b from-lemon-50/40 to-cream px-4 py-20 md:px-6 md:py-28"
  aria-labelledby="customize-heading"
>
  <div class="mx-auto max-w-3xl text-center">
    <h2
      id="customize-heading"
      class="font-display text-2xl font-semibold tracking-tight text-ink md:text-4xl"
    >
      {t.customize.title}
    </h2>
    <p class="mx-auto mt-6 max-w-2xl text-base font-light leading-relaxed text-stone-soft md:text-lg">
      {t.customize.body}
    </p>
    <a
      href="#order"
      class="mt-10 inline-flex items-center justify-center rounded-full bg-gold px-10 py-3.5 text-sm font-semibold text-white shadow-soft transition-colors duration-300 hover:bg-gold-dark hover:shadow-card"
    >
      {t.customize.cta}
    </a>
  </div>
</section>
