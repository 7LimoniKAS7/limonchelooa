---
import type { Messages } from "../i18n/messages";

interface Props {
  t: Messages;
}

const { t } = Astro.props;
---

<section
  id="experience"
  class="scroll-mt-24 bg-cream px-4 py-20 md:px-6 md:py-24"
  aria-labelledby="experience-heading"
>
  <div class="mx-auto max-w-3xl text-center">
    <h2
      id="experience-heading"
      class="font-display text-2xl font-semibold tracking-tight text-ink md:text-3xl"
    >
      {t.experience.title}
    </h2>
    <p class="mx-auto mt-8 max-w-2xl text-base font-light leading-relaxed text-stone-soft md:text-lg md:leading-loose">
      {t.experience.body}
    </p>
  </div>
</section>
