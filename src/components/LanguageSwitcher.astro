---
import { getLocalizedPath, locales, type Locale } from "../i18n/config";
import type { Messages } from "../i18n/messages";

interface Props {
  locale: Locale;
  t: Messages;
}

const { locale, t } = Astro.props;
---

<div class="language-switcher shrink-0" aria-label={t.language.label}>
  <span class="sr-only">{t.language.current}: {t.language.options[locale]}</span>
  <div
    class="inline-flex items-center gap-1 rounded-full border border-gold-light/35 bg-white/20 p-1 text-[0.68rem] font-semibold uppercase leading-none shadow-sm backdrop-blur-md"
    role="group"
    aria-label={t.language.choose}
  >
    {
      locales.map((item) => (
        <a
          href={getLocalizedPath(item)}
          data-locale-link
          data-locale={item}
          aria-current={item === locale ? "page" : undefined}
          title={t.language.options[item]}
          class:list={[
            "rounded-full px-2.5 py-2 transition-colors duration-300",
            item === locale
              ? "bg-cream text-ink shadow-sm"
              : "text-inherit hover:bg-white/20 hover:text-inherit",
          ]}
        >
          {item.toUpperCase()}
        </a>
      ))
    }
  </div>
</div>

<script>
  document.querySelectorAll("[data-locale-link]").forEach((link) => {
    link.addEventListener("click", () => {
      if (!(link instanceof HTMLAnchorElement)) return;

      const locale = link.dataset.locale;
      if (locale) localStorage.setItem("limoncello-locale", locale);

      if (window.location.hash && !link.href.includes("#")) {
        link.href = `${link.href.replace(/#.*$/, "")}${window.location.hash}`;
      }
    });
  });
</script>
