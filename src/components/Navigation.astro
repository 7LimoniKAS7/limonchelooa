---
const links = [
  { href: "#story", label: "Story" },
  { href: "#highlights", label: "Craft" },
  { href: "#ingredients", label: "Ingredients" },
  { href: "#customize", label: "Customize" },
  { href: "#showcase", label: "Shop" },
  { href: "#experience", label: "Experience" },
  { href: "#order", label: "Order" },
  { href: "#footer-contact", label: "Contact" },
];
---

<header
  class="sticky top-0 z-50 border-b border-lemon-300/50 bg-gradient-to-b from-lemon-100/95 to-lemon-200/90 backdrop-blur-md transition-shadow duration-300 hover:shadow-soft"
>
  <nav
    class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 md:px-6 md:py-4"
    aria-label="Primary"
  >
    <a
      href="#hero"
      class="group flex shrink-0 items-center gap-2 text-sm font-semibold tracking-tight text-ink transition-colors hover:text-gold-dark md:text-base"
    >
      <span
        class="flex h-8 w-8 items-center justify-center rounded-full bg-white/70 text-lg shadow-sm ring-1 ring-lemon-300/40 transition-transform duration-300 group-hover:scale-105"
        aria-hidden="true">🍋</span>
      <span class="hidden sm:inline">Kaş Limoncello</span>
    </a>
    <ul
      class="-mr-2 flex max-w-[min(100vw-8rem,28rem)] flex-nowrap items-center justify-end gap-0.5 overflow-x-auto pb-1 text-xs font-medium text-ink/85 md:max-w-none md:flex-wrap md:gap-2 md:overflow-visible md:pb-0 md:text-sm"
    >
      {
        links.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class="rounded-full px-2.5 py-1.5 transition-colors hover:bg-lemon-300/50 hover:text-ink md:px-3"
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
