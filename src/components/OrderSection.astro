---
import type { Messages } from "../i18n/messages";

interface Props {
  t: Messages;
}

const { t } = Astro.props;
---

<section
  id="order"
  class="scroll-mt-24 bg-cream px-4 py-20 md:px-6 md:py-28"
  aria-labelledby="order-heading"
>
  <div class="mx-auto max-w-xl">
    <h2
      id="order-heading"
      class="text-center font-display text-2xl font-semibold tracking-tight text-ink md:text-3xl"
    >
      {t.order.title}
    </h2>
    <p class="mx-auto mt-3 max-w-md text-center text-sm text-stone-soft">
      {t.order.lead}
    </p>

    <form
      id="limoncello-order-form"
      class="mt-10 space-y-5 rounded-3xl border border-gold-light/30 bg-white p-6 shadow-soft md:p-8"
      method="post"
      action="#"
      data-alert={t.order.alert}
      data-message-title={t.order.whatsapp.title}
      data-label-name={t.order.whatsapp.name}
      data-label-email={t.order.whatsapp.email}
      data-label-phone={t.order.whatsapp.phone}
      data-label-address={t.order.whatsapp.address}
      data-label-size={t.order.whatsapp.size}
      data-label-customization={t.order.whatsapp.customization}
    >
      <div>
        <label for="order-name" class="mb-1.5 block text-xs font-semibold uppercase tracking-wider text-stone-soft"
          >{t.order.labels.name}</label
        >
        <input
          id="order-name"
          name="name"
          type="text"
          required
          autocomplete="name"
          class="w-full rounded-xl border border-gold-light/40 bg-cream/30 px-4 py-3 text-sm text-ink transition-colors placeholder:text-stone-soft/60 focus:border-gold focus:bg-white focus:outline-none"
          placeholder={t.order.placeholders.name}
        />
      </div>
      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <label for="order-email" class="mb-1.5 block text-xs font-semibold uppercase tracking-wider text-stone-soft"
            >{t.order.labels.email}</label
          >
          <input
            id="order-email"
            name="email"
            type="email"
            autocomplete="email"
            class="w-full rounded-xl border border-gold-light/40 bg-cream/30 px-4 py-3 text-sm text-ink transition-colors placeholder:text-stone-soft/60 focus:border-gold focus:bg-white focus:outline-none"
            placeholder={t.order.placeholders.email}
          />
        </div>
        <div>
          <label for="order-phone" class="mb-1.5 block text-xs font-semibold uppercase tracking-wider text-stone-soft"
            >{t.order.labels.phone}</label
          >
          <input
            id="order-phone"
            name="phone"
            type="tel"
            autocomplete="tel"
            class="w-full rounded-xl border border-gold-light/40 bg-cream/30 px-4 py-3 text-sm text-ink transition-colors placeholder:text-stone-soft/60 focus:border-gold focus:bg-white focus:outline-none"
            placeholder={t.order.placeholders.phone}
          />
        </div>
      </div>
      <p class="text-xs text-stone-soft">
        {t.order.contactRequirement}
      </p>
      <div>
        <label for="order-address" class="mb-1.5 block text-xs font-semibold uppercase tracking-wider text-stone-soft"
          >{t.order.labels.address}</label
        >
        <textarea
          id="order-address"
          name="address"
          required
          rows={3}
          class="w-full resize-y rounded-xl border border-gold-light/40 bg-cream/30 px-4 py-3 text-sm text-ink transition-colors placeholder:text-stone-soft/60 focus:border-gold focus:bg-white focus:outline-none"
          placeholder={t.order.placeholders.address}
        ></textarea>
      </div>
      <div>
        <label for="order-size" class="mb-1.5 block text-xs font-semibold uppercase tracking-wider text-stone-soft"
          >{t.order.labels.size}</label
        >
        <select
          id="order-size"
          name="size"
          required
          class="w-full rounded-xl border border-gold-light/40 bg-cream/30 px-4 py-3 text-sm text-ink transition-colors focus:border-gold focus:bg-white focus:outline-none"
        >
          <option value="">{t.order.sizePlaceholder}</option>
          <option value="250ml">250ml</option>
          <option value="500ml">500ml</option>
          <option value="700ml">700ml</option>
        </select>
      </div>
      <div>
        <label
          for="order-notes"
          class="mb-1.5 block text-xs font-semibold uppercase tracking-wider text-stone-soft"
          >{t.order.labels.notes}</label
        >
        <textarea
          id="order-notes"
          name="notes"
          rows={3}
          class="w-full resize-y rounded-xl border border-gold-light/40 bg-cream/30 px-4 py-3 text-sm text-ink transition-colors placeholder:text-stone-soft/60 focus:border-gold focus:bg-white focus:outline-none"
          placeholder={t.order.placeholders.notes}
        ></textarea>
      </div>
      <button
        type="submit"
        class="w-full rounded-full bg-ink py-4 text-sm font-semibold text-cream transition-colors duration-300 hover:bg-gold-dark hover:shadow-card"
      >
        {t.order.button}
      </button>
    </form>
  </div>
</section>

<script is:inline>
  (function () {
    var form = document.getElementById("limoncello-order-form");
    if (!form) return;
    form.addEventListener("submit", function (e) {
      e.preventDefault();
      var email = document.getElementById("order-email");
      var phone = document.getElementById("order-phone");
      var hasEmail = email && email.value.trim();
      var hasPhone = phone && phone.value.trim();
      if (!hasEmail && !hasPhone) {
        alert(form.dataset.alert || "Please enter an email or phone number so we can confirm your order.");
        return;
      }
      var name = document.getElementById("order-name");
      var address = document.getElementById("order-address");
      var size = document.getElementById("order-size");
      var notes = document.getElementById("order-notes");

      var messageLines = [
        form.dataset.messageTitle || "New limoncello order request",
        (form.dataset.labelName || "Name") + ": " + (name && name.value ? name.value.trim() : "-"),
        (form.dataset.labelEmail || "Email") + ": " + (email && email.value ? email.value.trim() : "-"),
        (form.dataset.labelPhone || "Phone") + ": " + (phone && phone.value ? phone.value.trim() : "-"),
        (form.dataset.labelAddress || "Address") + ": " + (address && address.value ? address.value.trim() : "-"),
        (form.dataset.labelSize || "Bottle size") + ": " + (size && size.value ? size.value : "-"),
        (form.dataset.labelCustomization || "Customization") + ": " + (notes && notes.value ? notes.value.trim() : "-"),
      ];

      var waNumber = "905313186674";
      var waUrl =
        "https://wa.me/" +
        waNumber +
        "?text=" +
        encodeURIComponent(messageLines.join("\n"));

      var win = window.open(waUrl, "_blank", "noopener,noreferrer");
      if (win) {
        win.opener = null;
      } else {
        var link = document.createElement("a");
        link.href = waUrl;
        link.target = "_blank";
        link.rel = "noopener noreferrer";
        document.body.appendChild(link);
        link.click();
        link.remove();
      }

      form.reset();
    });
  })();
</script>
