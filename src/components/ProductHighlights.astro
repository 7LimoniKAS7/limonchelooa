---
const items = [
  {
    title: "Organic handpicked lemons",
    body: "Sun-ripened fruit from Kaş, selected by hand at peak aroma.",
    icon: "lemon",
  },
  {
    title: "Premium vodka base",
    body: "A refined neutral spirit—never cut with low-grade alcohol.",
    icon: "drop",
  },
  {
    title: "Handmade small batch",
    body: "Limited runs, slow maceration, and careful bottling by hand.",
    icon: "batch",
  },
  {
    title: "No additives",
    body: "No artificial flavors or preservatives—just pure ingredients.",
    icon: "leaf",
  },
];
---

<section
  id="highlights"
  class="scroll-mt-24 bg-gradient-to-b from-lemon-200/90 via-lemon-100 to-lemon-200/80 px-4 py-20 md:px-6 md:py-24"
  aria-labelledby="highlights-heading"
>
  <div class="mx-auto max-w-6xl">
    <h2
      id="highlights-heading"
      class="text-center font-display text-2xl font-semibold tracking-tight text-ink md:text-3xl"
    >
      Product highlights
    </h2>
    <p class="mx-auto mt-3 max-w-lg text-center text-sm text-ink/75 md:text-base">
      Four pillars define every bottle we release.
    </p>
    <ul
      class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4"
    >
      {
        items.map(({ title, body, icon }) => (
          <li>
            <article
              class="group flex h-full flex-col rounded-3xl border border-lemon-300/50 bg-white/90 p-6 shadow-soft backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:border-gold/50 hover:shadow-card"
            >
              <div
                class="mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-lemon-100 text-gold-dark transition-colors duration-300 group-hover:bg-lemon-200"
                aria-hidden="true"
              >
                {icon === "lemon" && (
                  <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c-2 4-6 6-6 10a6 6 0 1012 0c0-4-4-6-6-10z" />
                  </svg>
                )}
                {icon === "drop" && (
                  <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 2.25c-3 4.5-6 7.5-6 11.25a6 6 0 1012 0c0-3.75-3-6.75-6-11.25z" />
                  </svg>
                )}
                {icon === "batch" && (
                  <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3v2.25M14.25 3v2.25M5.25 8.25h13.5M6 5.25h12a1.5 1.5 0 011.5 1.5v12a1.5 1.5 0 01-1.5 1.5H6a1.5 1.5 0 01-1.5-1.5v-12A1.5 1.5 0 016 5.25z" />
                  </svg>
                )}
                {icon === "leaf" && (
                  <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 21c-4.5-3-7.5-7.5-7.5-12 0-3 2.25-5.25 5.25-5.25 4.5 0 7.5 3 7.5 7.5 0 4.5-2.25 8.25-5.25 9.75z" />
                  </svg>
                )}
              </div>
              <h3 class="text-lg font-semibold text-ink">{title}</h3>
              <p class="mt-2 flex-1 text-sm font-light leading-relaxed text-ink/75">
                {body}
              </p>
            </article>
          </li>
        ))
      }
    </ul>
  </div>
</section>
