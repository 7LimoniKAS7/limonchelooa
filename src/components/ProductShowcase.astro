---
import { Image } from "astro:assets";
import productImage from "../assets/product/limoncello.jpeg";
---

<section
  id="showcase"
  class="scroll-mt-24 bg-white px-4 py-20 md:px-6 md:py-24"
  aria-labelledby="showcase-heading"
>
  <div class="mx-auto max-w-6xl">
    <h2
      id="showcase-heading"
      class="text-center font-display text-2xl font-semibold tracking-tight text-ink md:text-3xl"
    >
      Product showcase
    </h2>
    <p class="mx-auto mt-3 max-w-lg text-center text-sm text-stone-soft">
      Frosted glass, hand-labeled. Choose the size that fits your table—or your
      evening.
    </p>

    <article
      class="mx-auto mt-12 max-w-md overflow-hidden rounded-3xl border border-gold-light/30 bg-cream shadow-card transition-shadow duration-300 hover:shadow-lg"
    >
      <div class="aspect-[4/5] overflow-hidden bg-lemon-100/50">
        <Image
          src={productImage}
          alt="Premium limoncello bottle beside fresh lemons"
          width={800}
          height={1000}
          class="h-full w-full object-cover transition-transform duration-500 hover:scale-[1.02]"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="p-6 md:p-8">
        <h3 class="text-lg font-semibold text-ink">Kaş Signature Limoncello</h3>
        <p class="mt-2 text-sm font-light leading-relaxed text-stone-soft">
          Bright citrus oils, silken body, and a clean finish—best enjoyed
          ice-cold after a coastal meal.
        </p>
        <div class="mt-6 flex flex-wrap gap-2">
          {
            ["250ml", "500ml", "700ml"].map((size) => (
              <span class="rounded-full border border-gold-light/40 bg-white px-3 py-1 text-xs font-medium text-ink">
                {size}
              </span>
            ))
          }
        </div>
        <a
          href="#order"
          class="mt-8 flex w-full items-center justify-center rounded-full bg-ink py-3.5 text-sm font-semibold text-cream transition-all duration-300 hover:-translate-y-0.5 hover:bg-gold-dark"
        >
          Add to Cart
        </a>
      </div>
    </article>
  </div>
</section>
