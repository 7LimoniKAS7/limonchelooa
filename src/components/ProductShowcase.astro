---
import { Image } from "astro:assets";
import productImage from "../assets/product/limoncello.jpeg";

const sizes = ["250ml", "500ml", "700ml"];
---

<section
  id="showcase"
  class="scroll-mt-24 bg-white px-4 py-20 md:px-6 md:py-24"
  aria-labelledby="showcase-heading"
>
  <div class="mx-auto max-w-6xl">
    <h2
      id="showcase-heading"
      class="text-center font-display text-2xl font-semibold tracking-tight text-ink md:text-3xl"
    >
      Product showcase
    </h2>
    <p class="mx-auto mt-3 max-w-lg text-center text-sm text-stone-soft">
      Frosted glass, hand-labeled. Choose the size that fits your table—or your
      evening.
    </p>

    <article
      class="mx-auto mt-12 max-w-md overflow-hidden rounded-3xl border border-gold-light/30 bg-cream shadow-card transition-shadow duration-300 hover:shadow-lg"
    >
      <div class="aspect-[4/5] overflow-hidden bg-lemon-100/50">
        <Image
          src={productImage}
          alt="Premium limoncello bottle beside fresh lemons"
          width={800}
          height={1000}
          class="h-full w-full object-cover"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="p-6 md:p-8">
        <h3 class="text-lg font-semibold text-ink">Kaş Signature Limoncello</h3>
        <p class="mt-2 text-sm font-light leading-relaxed text-stone-soft">
          Bright citrus oils, silken body, and a clean finish—best enjoyed
          ice-cold after a coastal meal.
        </p>
        <form id="product-quick-order-form" class="mt-6" action="#">
          <fieldset>
            <legend class="sr-only">Choose bottle size</legend>
            <div class="flex flex-wrap gap-2">
              {
                sizes.map((size) => (
                  <label class="cursor-pointer">
                    <input
                      class="peer sr-only"
                      type="radio"
                      name="quick-size"
                      value={size}
                      checked={size === "500ml"}
                    />
                    <span class="flex h-9 min-w-16 items-center justify-center rounded-lg border border-gold-light/40 bg-white px-3 text-xs font-medium text-ink transition-colors peer-checked:border-ink peer-checked:bg-ink peer-checked:text-cream peer-focus-visible:outline peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-gold">
                      {size}
                    </span>
                  </label>
                ))
              }
            </div>
          </fieldset>
          <button
            type="submit"
            class="mt-8 flex w-full items-center justify-center rounded-lg bg-ink py-3.5 text-sm font-semibold text-cream transition-colors duration-300 hover:bg-gold-dark"
          >
            Order Selected Size
          </button>
        </form>
      </div>
    </article>
  </div>
</section>

<script is:inline>
  (function () {
    var form = document.getElementById("product-quick-order-form");
    if (!form) return;

    form.addEventListener("submit", function (e) {
      e.preventDefault();
      var selected = form.querySelector('input[name="quick-size"]:checked');
      var size = selected && selected.value ? selected.value : "500ml";
      var messageLines = [
        "Yeni direkt limoncello siparis istegi",
        "Product: Kas Signature Limoncello",
        "Bottle size: " + size,
        "Customization: Yok, direkt almak istiyorum.",
      ];

      var waNumber = "905313186674";
      var waUrl =
        "https://wa.me/" +
        waNumber +
        "?text=" +
        encodeURIComponent(messageLines.join("\n"));

      var win = window.open(waUrl, "_blank", "noopener,noreferrer");
      if (!win) window.location.href = waUrl;
    });
  })();
</script>
