<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const motion = {
    revealY: 26,
    revealDuration: 0.82,
    revealStagger: 0.055,
    scrub: 0.36,
    ease: "power3.out",
  };

  const sectionProfiles = {
    hero: {
      glow: "rgba(246, 214, 66, 0.2)",
      light: "72% 18%",
      strength: 0.18,
    },
    story: {
      glow: "rgba(201, 169, 98, 0.16)",
      light: "50% 8%",
      strength: 0.14,
    },
    highlights: {
      glow: "rgba(246, 214, 66, 0.2)",
      light: "20% 12%",
      strength: 0.16,
    },
    ingredients: {
      glow: "rgba(6, 63, 92, 0.1)",
      light: "82% 18%",
      strength: 0.12,
    },
    customize: {
      glow: "rgba(201, 169, 98, 0.14)",
      light: "50% 10%",
      strength: 0.12,
    },
    showcase: {
      glow: "rgba(246, 214, 66, 0.16)",
      light: "66% 16%",
      strength: 0.14,
    },
    experience: {
      glow: "rgba(255, 248, 232, 0.22)",
      light: "44% 10%",
      strength: 0.1,
    },
    testimonials: {
      glow: "rgba(201, 169, 98, 0.12)",
      light: "78% 16%",
      strength: 0.1,
    },
    urgency: {
      glow: "rgba(246, 214, 66, 0.18)",
      light: "62% 12%",
      strength: 0.16,
    },
    order: {
      glow: "rgba(246, 214, 66, 0.14)",
      light: "50% 12%",
      strength: 0.12,
    },
  };

  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

  if (!reducedMotion.matches) {
    ScrollTrigger.config({
      ignoreMobileResize: true,
    });

    const sections = Array.from(document.querySelectorAll("main > section"));
    const revealItems = [];

    function profileFor(section) {
      return sectionProfiles[section.id] || sectionProfiles.story;
    }

    function shouldReveal(item, candidates) {
      if (item.closest("script, style, [data-motion-managed]")) return false;

      const parent = candidates.find((candidate) => {
        if (candidate === item) return false;
        return (
          candidate.matches("article, blockquote, figure, form, li") &&
          candidate.contains(item)
        );
      });

      return !parent;
    }

    function decorateSection(section) {
      const profile = profileFor(section);
      const managed = section.hasAttribute("data-motion-managed");

      if (!managed) {
        section.classList.add("motion-section");
      }

      section.style.setProperty("--motion-glow", profile.glow);
      section.style.setProperty("--motion-light", profile.light);
      section.style.setProperty("--motion-strength", String(profile.strength));

      ScrollTrigger.create({
        trigger: section,
        start: "top 62%",
        end: "bottom 38%",
        onToggle: (self) => section.classList.toggle("is-motion-active", self.isActive),
      });

      if (managed) return;

      const candidates = Array.from(
        section.querySelectorAll("h1, h2, h3, p, article, blockquote, figure, form, li"),
      );

      candidates
        .filter((item) => shouldReveal(item, candidates))
        .slice(0, 16)
        .forEach((item) => {
          item.setAttribute("data-motion-reveal", "");
          revealItems.push(item);
        });
    }

    sections.forEach(decorateSection);

    document
      .querySelectorAll("main article, main blockquote, main form")
      .forEach((item) => item.classList.add("motion-card"));

    document
      .querySelectorAll("main a[href^='#'], main button[type='submit']")
      .forEach((item) => item.classList.add("motion-cta"));

    document
      .querySelectorAll("main img")
      .forEach((item) => item.classList.add("motion-image"));

    gsap.set(revealItems, {
      autoAlpha: 0,
      y: motion.revealY,
      force3D: true,
    });

    ScrollTrigger.batch(revealItems, {
      start: "top 84%",
      once: true,
      interval: 0.08,
      batchMax: 8,
      onEnter: (batch) => {
        batch.forEach((item) => {
          item.style.willChange = "transform, opacity";
        });

        gsap.to(batch, {
          autoAlpha: 1,
          y: 0,
          duration: motion.revealDuration,
          stagger: motion.revealStagger,
          ease: motion.ease,
          overwrite: "auto",
          onComplete: () => {
            batch.forEach((item) => {
              item.style.willChange = "auto";
            });
          },
        });
      },
    });

    document.documentElement.classList.add("motion-ready");
  } else {
    document.documentElement.classList.add("motion-reduced");
  }
</script>

<style is:global>
  :root {
    --motion-ease: cubic-bezier(0.22, 1, 0.36, 1);
    --motion-duration: 720ms;
    --motion-hover-duration: 520ms;
  }

  .motion-section {
    position: relative;
    isolation: isolate;
    overflow: clip;
  }

  .motion-section::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    opacity: 0;
    transform: translate3d(0, 18px, 0) scale(1.01);
    background:
      radial-gradient(circle at var(--motion-light), var(--motion-glow), transparent 34%),
      linear-gradient(180deg, rgba(255, 248, 232, 0.08), transparent 48%, rgba(6, 63, 92, 0.04));
    transition:
      opacity var(--motion-duration) var(--motion-ease),
      transform var(--motion-duration) var(--motion-ease);
  }

  .motion-section.is-motion-active::before {
    opacity: var(--motion-strength);
    transform: translate3d(0, 0, 0) scale(1);
  }

  .motion-section > [data-scene-background] {
    position: absolute;
    z-index: 0;
  }

  .motion-section > :not([data-scene-background]) {
    position: relative;
    z-index: 2;
  }

  [data-motion-reveal] {
    backface-visibility: hidden;
  }

  .motion-card,
  .motion-cta,
  .motion-image {
    backface-visibility: hidden;
    transform: translate3d(0, 0, 0);
  }

  .motion-card {
    transition:
      transform var(--motion-hover-duration) var(--motion-ease),
      box-shadow var(--motion-hover-duration) var(--motion-ease),
      border-color var(--motion-hover-duration) var(--motion-ease),
      background-color var(--motion-hover-duration) var(--motion-ease);
  }

  .motion-cta {
    transition:
      transform var(--motion-hover-duration) var(--motion-ease),
      box-shadow var(--motion-hover-duration) var(--motion-ease),
      background-color var(--motion-hover-duration) var(--motion-ease),
      border-color var(--motion-hover-duration) var(--motion-ease),
      color var(--motion-hover-duration) var(--motion-ease);
  }

  .motion-image {
    transition: transform 900ms var(--motion-ease);
  }

  @media (hover: hover) {
    .motion-card:hover {
      transform: translate3d(0, -3px, 0);
    }

    .motion-cta:hover {
      transform: translate3d(0, -2px, 0);
    }

    .motion-card:hover .motion-image,
    .motion-image:hover {
      transform: scale(1.018);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .motion-section::before {
      display: none;
    }

    [data-motion-reveal],
    .motion-card,
    .motion-cta,
    .motion-image {
      transform: none !important;
      transition: none !important;
    }
  }
</style>
