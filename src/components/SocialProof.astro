---
const quotes = [
  {
    text: "The cleanest limoncello I have tasted outside the Amalfi coast. Kaş in a glass.",
    author: "Elif K.",
    role: "İstanbul",
  },
  {
    text: "We ordered a custom sweetness level for our wedding favors—flawless and memorable.",
    author: "Marco & Ayşe",
    role: "Antalya",
  },
  {
    text: "Small batch shows. You can actually taste the peel, not just sugar.",
    author: "James R.",
    role: "London",
  },
];
---

<section
  id="testimonials"
  class="scroll-mt-24 border-t border-gold-light/20 bg-white px-4 py-16 md:px-6 md:py-20"
  aria-labelledby="testimonials-heading"
>
  <div class="mx-auto max-w-6xl">
    <h2
      id="testimonials-heading"
      class="text-center font-display text-xl font-semibold tracking-tight text-ink md:text-2xl"
    >
      Loved at the table
    </h2>
    <p class="mx-auto mt-2 max-w-md text-center text-xs text-stone-soft md:text-sm">
      Early notes from guests who have shared a bottle at our table.
    </p>
    <ul
      class="mt-10 grid gap-6 md:grid-cols-3"
      role="list"
    >
      {
        quotes.map(({ text, author, role }) => (
          <li>
            <blockquote class="flex h-full flex-col rounded-2xl border border-gold-light/25 bg-cream/60 p-6 shadow-soft transition-colors duration-300 hover:border-gold/30 hover:shadow-card">
              <p class="flex-1 text-sm font-light italic leading-relaxed text-ink md:text-base">
                “{text}”
              </p>
              <footer class="mt-4 border-t border-gold-light/20 pt-4">
                <cite class="not-italic">
                  <span class="text-sm font-semibold text-ink">{author}</span>
                  <span class="mt-0.5 block text-xs text-stone-soft">{role}</span>
                </cite>
              </footer>
            </blockquote>
          </li>
        ))
      }
    </ul>
  </div>
</section>
