---
import type { Messages } from "../i18n/messages";

interface Props {
  t: Messages;
}

const { t } = Astro.props;
---

<section
  id="story"
  class="scroll-mt-24 border-t border-lemon-300/40 bg-gradient-to-b from-lemon-100 to-lemon-50 px-4 py-20 md:px-6 md:py-28"
  aria-labelledby="story-heading"
>
  <div class="mx-auto max-w-3xl text-center">
    <h2
      id="story-heading"
      class="font-display text-2xl font-semibold tracking-tight text-ink md:text-4xl"
    >
      {t.story.title}
    </h2>
    <div
      class="mx-auto mt-6 h-px w-16 bg-gradient-to-r from-transparent via-lemon-400 to-transparent"
      aria-hidden="true"
    >
    </div>
    <p
      class="mt-8 text-base font-light leading-relaxed text-ink/80 md:text-lg md:leading-loose"
    >
      {t.story.body}
    </p>
  </div>
</section>
